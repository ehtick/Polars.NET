{
  "$schema": "https://raw.githubusercontent.com/dotnet/docfx/main/schemas/docfx.schema.json",
  "metadata": [
    {
      "src": [
        {
          "files": [
            "Polars.CSharp/Polars.CSharp.csproj"
          ],
          "src": ".."
        }
      ],
      "dest": "api/csharp",
      "disableGitFeatures": false,
      "disableDefaultFilter": false,
      "properties": {
        "tocLevel": "4"
      }
    }
  ],
  "build": {
    "content": [
      {
        "files": [
          "api/**.md",
          "api/**.yml",
          "api/csharp/**",
          "api/fsharp/**",
          "*.md",
          "api/toc.yml",
          "toc.yml",
          "articles/**.md"
        ]
      }
    ],
    "resource": [
      {
        "files": [
          "images/**"
        ]
      }
    ],
    "output": "_site",
    "template": [
      "default",
      "modern"
    ],
    "globalMetadata": {
      "_appName": "Polars.NET",
      "_appTitle": "Polars.NET",
      "_appFooter": "Copyright © 2026 Polars.NET, Qinglei",
      "_enableSearch": true,
      "_gitContribute": {
        "repo": "https://github.com/ErrorLSC/Polars.NET", 
        "branch": "main"
      }
    }
  }
}